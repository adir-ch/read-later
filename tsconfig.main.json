{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/main",
    "lib": ["ES2022"],
    "types": ["node"],
    "esModuleInterop": true
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"]
}
